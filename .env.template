# 配置服务端向前端暴露的可用模型列表；通常用逗号分隔，支持 model@Provider，-all 表示先清空内置模型后再追加。
CUSTOM_MODELS=

# 配置新会话默认选中的模型名称；应当与 CUSTOM_MODELS 或内置模型列表中的模型名一致，留空时使用项目默认模型。
DEFAULT_MODEL=

# 配置兼容 OpenAI 聊天补全接口的基础地址；使用代理、自建网关或兼容接口时填写该服务地址。
BASE_URL=

# 配置 OpenAI 图片生成/编辑接口的基础地址；留空时跟随 BASE_URL。若聊天网关对长耗时 multipart 图片接口有超时限制，可单独指定支持图片接口的上游。
OPENAI_IMAGES_URL=

# 配置服务端调用 OpenAI 或兼容接口使用的密钥；真实值属于敏感凭据，不要提交到 Git。
OPENAI_API_KEY=sk-xxxx

# 控制前端是否隐藏余额查询入口；设为 1/true 时隐藏，避免用户在界面上查询服务端密钥余额。
HIDE_BALANCE_QUERY=

# 控制前端是否隐藏用户自填接口密钥的入口；设为 1/true 时强制使用服务端配置的密钥。
HIDE_USER_API_KEY=

# 配置新会话默认 temperature；数值范围通常为 0 到 2，数值越高输出越随机，留空时使用项目默认值。
OPENAI_TEMPERATURE=

# 配置 Responses 接口的 max_output_tokens 默认上限；GPT-5.6 系列最大为 128000，用于限制单次回复最多生成的输出 token。
OPENAI_MAX_OUTPUT_TOKENS=

# 配置 OpenAI Responses 接口的自定义请求地址；需要走代理、网关或兼容层时使用。
OPENAI_RESPONSES_URL=

# 控制 Responses API 是否开启服务端存储；设为 1/true 时便于使用 previous_response_id 和后台日志追踪。
OPENAI_STORE_RESPONSES=

# 配置支持 reasoning 的模型默认推理强度；GPT-5.6 支持 none、low、medium、high、xhigh、max。
OPENAI_REASONING_EFFORT=

# 配置 Responses 接口文本输出详略程度；常见值如 low、medium、high，用于影响默认回复的简洁或详细倾向。
OPENAI_TEXT_VERBOSITY=

# 配置历史消息压缩触发阈值；会话上下文超过该长度后更倾向于压缩旧消息，留空时使用项目默认阈值。
OPENAI_COMPRESS_MESSAGE_LENGTH_THRESHOLD=

# 配置即梦 MCP 调用所需的 Bearer Token；存在时服务端会默认认为 MCP 能力可用，真实值不要提交到 Git。
JIMENG_MCP_TOKEN=

# 配置前端公开配置版本号；版本变化可触发客户端重新接受服务端默认配置，用于覆盖旧浏览器缓存中的设置。
WEBUI_CONFIG_VERSION=

# 配置前端被服务端锁定的设置项列表；用逗号分隔，被锁定字段不允许用户在浏览器端覆盖。
WEBUI_LOCKED_FIELDS=

# 配置前端允许选择的模型白名单；用逗号分隔，通常与 CUSTOM_MODELS 保持一致以限制可见模型。
WEBUI_ALLOWED_MODELS=

# 旧版访问码配置；当前仍作为 legacy/normal 权限兼容读取，新部署建议迁移到 ACCESS_CODE_NORMAL。
CODE=your-password

# 配置管理员级访问码列表；多个值用英文逗号分隔，通常不受普通每日 token 限额约束。
ACCESS_CODE_ADMIN=

# 配置高级用户访问码列表；多个值用英文逗号分隔，适合给高额度或受信任用户使用。
ACCESS_CODE_ADVANCED=

# 配置高级访问码每日 token 限额；按 ACCESS_QUOTA_TIME_ZONE 指定时区重置。
ACCESS_ADVANCED_DAILY_TOKENS=500000

# 配置普通用户访问码列表；多个值用英文逗号分隔，是默认受限访问入口。
ACCESS_CODE_NORMAL=

# 配置普通访问码每日 token 限额；用于控制普通用户每天可消耗的模型 token。
ACCESS_NORMAL_DAILY_TOKENS=200000

# 配置访问控制白名单 IP 或 CIDR 列表；多个值用英文逗号分隔，命中后可使用白名单倍率或放宽部分限流。
ACCESS_IP_WHITELIST=

# 配置白名单 IP 的 token 额度倍率；用于给可信网络提高每日可用额度。
ACCESS_WHITELIST_TOKEN_MULTIPLIER=2

# 配置单个访问码突发用量统计窗口秒数；用于短时间高频请求限流。
ACCESS_BURST_WINDOW_SECONDS=600

# 配置单个访问码在突发窗口内允许消耗的 token 上限；超过后进入冷却或拒绝。
ACCESS_BURST_TOKEN_LIMIT=100000

# 配置访问码触发突发限流后的冷却秒数；冷却期间相关请求会受限。
ACCESS_BURST_COOLDOWN_SECONDS=900

# 配置每日额度重置使用的时区；建议与主要用户所在地区或运营口径一致。
ACCESS_QUOTA_TIME_ZONE=Asia/Shanghai

# 控制是否启用设备 ID 识别；开启后可用 cookie/设备维度辅助限流和追踪。
ACCESS_DEVICE_ID_ENABLED=false

# 配置设备 ID 签名密钥；属于敏感凭据，用于防止客户端伪造设备标识，正式环境必须使用长随机字符串。
ACCESS_DEVICE_ID_SECRET=

# 配置设备 ID 写入浏览器时使用的 cookie 名称；改名会影响已有客户端识别连续性。
ACCESS_DEVICE_ID_COOKIE_NAME=neatchat_device_id

# 配置设备 ID cookie 的有效天数；过期后客户端会重新生成或重新绑定设备标识。
ACCESS_DEVICE_ID_MAX_AGE_DAYS=180

# 控制是否启用按 IP 维度的突发用量保护；用于抑制同一 IP 下多个访问码的集中滥用。
ACCESS_IP_BURST_GUARD_ENABLED=false

# 配置单个 IP 在突发窗口内允许消耗的 token 上限；仅在 IP 突发保护开启时生效。
ACCESS_IP_BURST_TOKEN_LIMIT=2000000

# 配置 IP 突发保护的统计窗口秒数；窗口越短越偏向拦截瞬时高并发。
ACCESS_IP_BURST_WINDOW_SECONDS=600

# 配置 Upstash/Vercel KV 兼容 Redis REST 接口地址；用于跨实例保存访问码用量和限流状态。
NEATCHAT_REDIS_KV_REST_API_URL=

# 配置 Redis REST 写入令牌；属于敏感凭据，用于服务端读写访问控制状态。
NEATCHAT_REDIS_KV_REST_API_TOKEN=

# 配置 Redis REST 只读令牌；通常用于只读检查或备用场景，不能替代写入令牌。
NEATCHAT_REDIS_KV_REST_API_READ_ONLY_TOKEN=

# 配置 KV 服务的通用连接 URL；主要用于平台集成或兼容其他 Redis/KV 客户端。
NEATCHAT_REDIS_KV_URL=

# 配置标准 Redis 协议连接 URL；适合支持 redis:// 的运行环境或后续扩展使用。
NEATCHAT_REDIS_REDIS_URL=

# 配置访问用量写入 Redis 时使用的 key 前缀；用于区分环境、项目或部署实例，避免数据互相污染。
ACCESS_USAGE_REDIS_PREFIX=neatchat:access-usage

# 配置访问用量状态版本；需要让老 cookie 不再命中旧 daily/burst/cooldown 状态时递增或改名。
ACCESS_USAGE_STATE_VERSION=

# 配置前端更新公告 JSON；可包含 enabled、date、items、sections、note，用于新构建后展示公告弹窗，建议保持为单行 JSON。
WEBUI_ANNOUNCEMENT_JSON=

# 配置服务端请求外网时使用的代理地址；只在需要通过本地代理访问上游接口时填写。
PROXY_URL=http://localhost:7890

# 控制是否启用 MCP 功能；设为 true 时开启，留空时默认关闭，但部分 MCP 令牌存在时可能由服务端自动启用。
ENABLE_MCP=

# 配置 Google Gemini 接口密钥；需要使用 Google/Gemini 模型时填写，真实值不要提交到 Git。
GOOGLE_API_KEY=

# 配置 Google Gemini 接口基础地址；需要自定义代理或网关时填写，留空时使用官方默认地址。
GOOGLE_URL=

# 配置 OpenAI 组织 ID；仅在 OpenAI 账号需要按组织隔离计费或权限时填写。
OPENAI_ORG_ID=

# 控制是否禁用 GPT-4 相关模型；设为 1 时阻止用户使用 GPT-4，主要用于兼容旧配置。
DISABLE_GPT4=

# 旧版余额查询开关；设为 1 时允许用户查询余额，当前更推荐使用 HIDE_BALANCE_QUERY 做反向控制。
ENABLE_BALANCE_QUERY=

# 控制是否禁用从 URL 解析设置；设为 1 时关闭该能力，避免用户通过链接覆盖部分客户端设置。
DISABLE_FAST_LINK=

# 配置 Anthropic Claude 接口密钥；需要使用 Anthropic 模型时填写，真实值不要提交到 Git。
ANTHROPIC_API_KEY=

# 配置 Anthropic 接口版本；使用 Claude 接口时可按上游要求指定版本，留空时使用项目默认行为。
ANTHROPIC_API_VERSION=

# 配置 Anthropic 接口基础地址；需要自定义代理、网关或兼容服务时填写。
ANTHROPIC_URL=

# 配置允许访问的 WebDAV 端点白名单；多个值用英文逗号分隔，留空表示不额外放开。
WHITE_WEBDAV_ENDPOINTS=
