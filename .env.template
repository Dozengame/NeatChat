# OpenAI API Key，必填。正式环境不要把真实值提交到代码仓库。
OPENAI_API_KEY=sk-xxxx

# 旧版访问密码变量，兼容保留。多个密码可用英文逗号分隔。
# 新部署建议留空，并改用下面的 ACCESS_CODE_ADMIN / ACCESS_CODE_ADVANCED / ACCESS_CODE_NORMAL。
CODE=your-password

# 管理员层级访问密钥。建议只配置一个唯一值，默认不限制每日 token 用量。
ACCESS_CODE_ADMIN=

# 高级用户层级访问密钥。可多人共用同一个值，默认按“访问密钥 + IP + 设备 ID”每天 500000 token。
ACCESS_CODE_ADVANCED=
ACCESS_ADVANCED_DAILY_TOKENS=500000

# 普通用户层级访问密钥。可多人共用同一个值，默认按“访问密钥 + IP + 设备 ID”每天 200000 token。
ACCESS_CODE_NORMAL=
ACCESS_NORMAL_DAILY_TOKENS=200000

# IP 白名单，多个值用英文逗号分隔。支持精确 IPv4/IPv6，也支持 IPv4 CIDR。
# 命中白名单的 IP 默认获得 2 倍每日 token 用量。
ACCESS_IP_WHITELIST=
ACCESS_WHITELIST_TOKEN_MULTIPLIER=2

# 短时间 token 消耗保护。默认 10 分钟内超过 100000 token 后，冷却 15 分钟。
ACCESS_BURST_WINDOW_SECONDS=600
ACCESS_BURST_TOKEN_LIMIT=100000
ACCESS_BURST_COOLDOWN_SECONDS=900
ACCESS_QUOTA_TIME_ZONE=Asia/Shanghai

# 设备 ID 开关。开启后按“访问密钥 + IP + 设备 ID”分别统计，避免同公司共用出口 IP 时互相占用额度。
# ACCESS_DEVICE_ID_SECRET 必须填写长随机字符串，并且同一个正式环境的所有部署保持一致。
ACCESS_DEVICE_ID_ENABLED=false
ACCESS_DEVICE_ID_SECRET=
ACCESS_DEVICE_ID_COOKIE_NAME=neatchat_device_id
ACCESS_DEVICE_ID_MAX_AGE_DAYS=180

# 同一 IP 的聚合保护。用于拦截同一 IP 下通过大量设备 ID 集中消耗 token 的明显异常行为。
ACCESS_IP_BURST_GUARD_ENABLED=false
ACCESS_IP_BURST_TOKEN_LIMIT=2000000
ACCESS_IP_BURST_WINDOW_SECONDS=600

# 用量持久化存储。Vercel 正式环境建议配置 Redis REST 地址和 Token。
# 留空时只保存在当前进程内，重启、冷启动或多实例时统计可能不稳定。
# 如果 Vercel Upstash 已自动生成 NEATCHAT_REDIS_KV_REST_API_URL 和 NEATCHAT_REDIS_KV_REST_API_TOKEN，
# 项目也会自动识别；ACCESS_USAGE_REDIS_URL/TOKEN 可留空。
ACCESS_USAGE_REDIS_URL=
ACCESS_USAGE_REDIS_TOKEN=
ACCESS_USAGE_REDIS_PREFIX=neatchat:access-usage

# You can start service behind a proxy. (optional)
PROXY_URL=http://localhost:7890

# Enable MCP functionality (optional)
# Default: Empty (disabled)
# Set to "true" to enable MCP functionality
ENABLE_MCP=

# (optional)
# Default: Empty
# Google Gemini Pro API key, set if you want to use Google Gemini Pro API.
GOOGLE_API_KEY=

# (optional)
# Default: https://generativelanguage.googleapis.com/
# Google Gemini Pro API url without pathname, set if you want to customize Google Gemini Pro API url.
GOOGLE_URL=

# Override openai api request base url. (optional)
# Default: https://api.openai.com
# Examples: http://your-openai-proxy.com
BASE_URL=

# Specify OpenAI organization ID.(optional)
# Default: Empty
OPENAI_ORG_ID=

# (optional)
# Default: Empty
# If you do not want users to use GPT-4, set this value to 1.
DISABLE_GPT4=

# (optional)
# Default: Empty
# If you do not want users to input their own API key, set this value to 1.
HIDE_USER_API_KEY=

# (optional)
# Default: Empty
# If you do want users to query balance, set this value to 1.
ENABLE_BALANCE_QUERY=

# (optional)
# Default: Empty
# If you want to disable parse settings from url, set this value to 1.
DISABLE_FAST_LINK=

# (optional)
# Default: Empty
# To control custom models, use + to add a custom model, use - to hide a model, use name=displayName to customize model name, separated by comma.
CUSTOM_MODELS=

# (optional)
# Default: Empty
# Change default model
DEFAULT_MODEL=

# (optional)
# Default: Empty
# Change default temperature, from 0 to 2
OPENAI_TEMPERATURE=

# (optional)
# Default: Empty
# Custom Responses API endpoint. BASE_URL can also be set directly to an endpoint ending with /v1/responses.
OPENAI_RESPONSES_URL=

# (optional)
# Default: low
# Responses API reasoning effort: low, medium, high, xhigh
OPENAI_REASONING_EFFORT=

# (optional)
# Default: Empty
# Force max_output_tokens for every user after config fetch. Leave empty to use the reasoning defaults: low=10000, medium=20000, high=30000.
OPENAI_MAX_OUTPUT_TOKENS=

# (optional)
# Default: medium
# Responses API text verbosity: low, medium, high
OPENAI_TEXT_VERBOSITY=


# anthropic claude Api Key.(optional)
ANTHROPIC_API_KEY=

### anthropic claude Api version. (optional)
ANTHROPIC_API_VERSION=

### anthropic claude Api url (optional)
ANTHROPIC_URL=

### (optional)
WHITE_WEBDAV_ENDPOINTS=
